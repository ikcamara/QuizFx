<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quizfx.controllers.ConnexionController"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7ff, #eef2ff);">

    <children>
        <VBox layoutX="430.0" layoutY="140.0"
              prefWidth="420.0" prefHeight="420.0"
              spacing="14.0"
              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 28 30 22 30;">

            <children>
                <Label text="QuizFX"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;" />

                <Label text="Connexion"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;" />

                <Label text="Email"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <TextField fx:id="emailField"
                           promptText="Entrez votre email"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 12 10 12; -fx-border-color: #e5e7eb; -fx-background-color: #f9fafb; -fx-font-size: 14px;" />

                <Label text="Mot de passe"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <PasswordField fx:id="passwordField"
                               promptText="Entrez votre mot de passe"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 12 10 12; -fx-border-color: #e5e7eb; -fx-background-color: #f9fafb; -fx-font-size: 14px;" />

                <Label fx:id="errorLabel"
                       text=""
                       style="-fx-text-fill: #e11d48; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <Button text="Se connecter"
                        prefWidth="320.0"
                        style="-fx-background-color: #4f86ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 12; -fx-padding: 10 14 10 14;" />

                <Label text="Pas encore de compte ?"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px;" />

                <Hyperlink text="Créer un compte"
                           style="-fx-text-fill: #4f86ff; -fx-font-weight: bold;" />
            </children>
        </VBox>
    </children>
</AnchorPane>