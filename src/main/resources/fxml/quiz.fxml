<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #F4F6F9;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quizfx.controllers.QuizController">

    <fx:define>
        <ToggleGroup fx:id="reponsesGroup" />
    </fx:define>

    <children>
        <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="80.0" prefWidth="1280.0"
                    style="-fx-background-color: #00A2E8;">
            <children>
                <Label layoutX="65.0" layoutY="15.0"
                       prefHeight="62.0" prefWidth="107.0"
                       style="-fx-font-size: 30; -fx-text-fill: white;"
                       text="QuizFX" />

                <Label layoutX="564.0" layoutY="33.0"
                       style="-fx-font-size: 18; -fx-text-fill: white;"
                       text="Module :" />

                <Label fx:id="moduleLabel"
                       layoutX="664.0" layoutY="33.0"
                       style="-fx-font-size: 18; -fx-text-fill: white;"
                       text="Nom module" />

                <Label layoutX="1040.0" layoutY="32.0"
                       style="-fx-font-size: 18; -fx-text-fill: white;"
                       text="Question :" />

                <Label fx:id="numeroQuestionLabel"
                       layoutX="1150.0" layoutY="32.0"
                       style="-fx-font-size: 18; -fx-text-fill: white;"
                       text="1/10" />
            </children>
        </AnchorPane>

        <AnchorPane layoutX="346.0" layoutY="149.0"
                    prefHeight="535.0" prefWidth="590.0"
                    style="-fx-background-radius: 15; -fx-background-color: #FFFFFF;">
            <children>

                <Label fx:id="questionLabel"
                       layoutX="70.0" layoutY="38.0"
                       prefHeight="50.0" prefWidth="450.0"
                       style="-fx-alignment: center; -fx-font-size: 20;"
                       text="QUESTION" wrapText="true" />

                <RadioButton fx:id="rep1"
                             layoutX="59.0" layoutY="123.0"
                             mnemonicParsing="false"
                             prefHeight="55.0" prefWidth="471.0"
                             style="-fx-alignment: center; -fx-background-color: #E4E9F7; -fx-background-radius: 14; -fx-font-size: 15;"
                             text="Réponse 1"
                             toggleGroup="$reponsesGroup" />

                <RadioButton fx:id="rep2"
                             layoutX="59.0" layoutY="198.0"
                             mnemonicParsing="false"
                             prefHeight="55.0" prefWidth="471.0"
                             style="-fx-alignment: center; -fx-background-color: #E4E9F7; -fx-background-radius: 14; -fx-font-size: 15;"
                             text="Réponse 2"
                             toggleGroup="$reponsesGroup" />

                <RadioButton fx:id="rep3"
                             layoutX="59.0" layoutY="273.0"
                             mnemonicParsing="false"
                             prefHeight="55.0" prefWidth="471.0"
                             style="-fx-background-color: #E4E9F7; -fx-background-radius: 14; -fx-alignment: center; -fx-font-size: 15;"
                             text="Réponse 3"
                             toggleGroup="$reponsesGroup" />

                <RadioButton fx:id="rep4"
                             layoutX="59.0" layoutY="348.0"
                             mnemonicParsing="false"
                             prefHeight="55.0" prefWidth="471.0"
                             style="-fx-background-color: #E4E9F7; -fx-background-radius: 14; -fx-alignment: center; -fx-font-size: 15;"
                             text="Réponse 4"
                             toggleGroup="$reponsesGroup" />

                <Button layoutX="88.0" layoutY="456.0"
                        mnemonicParsing="false"
                        prefHeight="38.0" prefWidth="131.0"
                        style="-fx-background-color: #00A2E8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18;"
                        text="Valider"
                        onAction="#validerReponse" />

                <Button layoutX="363.0" layoutY="456.0"
                        mnemonicParsing="false"
                        prefHeight="38.0" prefWidth="131.0"
                        style="-fx-background-color: #E0E0E0; -fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 18;"
                        text="Annuler"
                        onAction="#annulerQuiz" />
            </children>
        </AnchorPane>
    </children>
</AnchorPane>