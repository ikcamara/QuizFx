<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quizfx.controllers.InscriptionController"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7ff, #eef2ff);">

    <children>
        <Label layoutX="90.0" layoutY="60.0"
               text="QuizFX"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;" />

        <VBox layoutX="430.0" layoutY="90.0"
              prefWidth="420.0" prefHeight="560.0"
              spacing="12.0"
              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 28 30 22 30;">

            <children>
                <Label text="Créer un compte"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;" />

                <Label text="Inscrivez-vous pour commencer le quiz"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px;" />

                <Label text="Nom complet"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <TextField fx:id="nomField"
                           promptText="Entrez votre nom"
                           prefWidth="360.0"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 12 10 12; -fx-border-color: #e5e7eb; -fx-background-color: #f9fafb; -fx-font-size: 14px;" />

                <Label text="Email"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <TextField fx:id="emailField"
                           promptText="Entrez votre email"
                           prefWidth="360.0"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 12 10 12; -fx-border-color: #e5e7eb; -fx-background-color: #f9fafb; -fx-font-size: 14px;" />

                <Label text="Mot de passe"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <PasswordField fx:id="passwordField"
                               promptText="Entrez votre mot de passe"
                               prefWidth="360.0"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 12 10 12; -fx-border-color: #e5e7eb; -fx-background-color: #f9fafb; -fx-font-size: 14px;" />

                <Label text="Confirmer le mot de passe"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirmez votre mot de passe"
                               prefWidth="360.0"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 12 10 12; -fx-border-color: #e5e7eb; -fx-background-color: #f9fafb; -fx-font-size: 14px;" />

                <Label fx:id="errorLabel"
                       text=""
                       wrapText="true"
                       prefWidth="360.0"
                       style="-fx-text-fill: #e11d48; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <Button text="S'inscrire"
                        onAction="#sinscrire"
                        prefWidth="360.0"
                        prefHeight="42.0"
                        style="-fx-background-color: #4f86ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 12;" />

                <Label text="Vous avez déjà un compte ?"
                       style="-fx-text-fill: #667085; -fx-font-size: 13px;" />

                <Hyperlink text="Se connecter"
                           onAction="#allerConnexion"
                           style="-fx-text-fill: #4f86ff; -fx-font-weight: bold;" />
            </children>
        </VBox>
    </children>
</AnchorPane>