<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #F8FAFC; -fx-background-radius: 10;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quizfx.controllers.ResultController">

    <children>
        <AnchorPane prefHeight="86.0" prefWidth="1280.0" style="-fx-background-color: #00A2E8;">
            <children>
                <Label layoutX="47.0" layoutY="27.0" style="-fx-font-weight: bold; -fx-font-size: 25;" text="QuizFX" />
                <Label layoutX="616.0" layoutY="34.0" style="-fx-text-fill: white;" text="Résultat" />
                <Button layoutX="1179.0" layoutY="28.0"
                        mnemonicParsing="false"
                        prefHeight="30.0" prefWidth="80.0"
                        style="-fx-background-radius: 10;"
                        text="Retour"
                        onAction="#retourAccueil" />
            </children>
        </AnchorPane>

        <Label layoutX="514.0" layoutY="138.0"
               prefHeight="86.0" prefWidth="124.0"
               style="-fx-font-weight: bold; -fx-font-size: 30;"
               text="Bravo" />

        <Label fx:id="nomLabel"
               layoutX="657.0" layoutY="156.0"
               prefHeight="49.0" prefWidth="180.0"
               style="-fx-font-size: 15;"
               text="Nom utilisateur" />

        <Label layoutX="727.0" layoutY="181.0" text="!" />

        <Label layoutX="556.0" layoutY="234.0"
               prefHeight="50.0" prefWidth="94.0"
               style="-fx-font-weight: bold; -fx-font-size: 25;"
               text="Score :" />

        <Label fx:id="scoreLabel"
               layoutX="663.0" layoutY="239.0"
               prefHeight="39.0" prefWidth="87.0"
               style="-fx-font-size: 20;"
               text="0" />

        <Label layoutX="527.0" layoutY="304.0"
               prefHeight="39.0" prefWidth="106.0"
               style="-fx-font-size: 20;"
               text="Module :" />

        <Label fx:id="moduleLabel"
               layoutX="653.0" layoutY="306.0"
               prefHeight="39.0" prefWidth="274.0"
               style="-fx-font-size: 20;"
               text="Nom du module" />

        <Label layoutX="457.0" layoutY="385.0"
               prefHeight="50.0" prefWidth="354.0"
               style="-fx-background-radius: 6; -fx-background-color: #E4E9F7;"
               text="✅ Bonne réponse :" />

        <Label layoutX="457.0" layoutY="460.0"
               prefHeight="50.0" prefWidth="354.0"
               style="-fx-background-radius: 6; -fx-background-color: #E4E9F7;"
               text="❎ Mauvaise réponse :" />

        <Label fx:id="bonneReponseLabel"
               layoutX="735.0" layoutY="401.0"
               prefHeight="18.0" prefWidth="51.0"
               text="0" />

        <Label fx:id="mauvaiseReponseLabel"
               layoutX="739.0" layoutY="476.0"
               text="0" />

        <Button layoutX="457.0" layoutY="545.0"
                mnemonicParsing="false"
                prefHeight="50.0" prefWidth="106.0"
                style="-fx-background-radius: 10;"
                text="Rejouer"
                onAction="#rejouerQuiz" />

        <Button layoutX="624.0" layoutY="545.0"
                mnemonicParsing="false"
                prefHeight="50.0" prefWidth="187.0"
                style="-fx-background-radius: 10;"
                text="Choisir un autre module"
                onAction="#choisirAutreModule" />
    </children>
</AnchorPane>